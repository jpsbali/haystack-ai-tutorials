# Haystack AI RAG Tutorials - Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# ===== LLM Provider API Keys =====
# OpenAI API Key (Required for most notebooks)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Optional - for Claude models)
# Get it from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Cohere API Key (Required for Notebook 2 - Reranking)
# Get it from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key_here

# ===== Web Search API Keys =====
# SerperDev API Key (Required for Notebook 3 - Web Fallback)
# Get it from: https://serper.dev/api-key
SERPER_API_KEY=your_serper_api_key_here

# ===== Graph Database Configuration (for Notebook 4) =====
# Neo4j Connection URI
NEO4J_URI=bolt://localhost:7687

# Neo4j Authentication
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ===== Optional: Hugging Face =====
# Hugging Face API Token (Optional - for downloading models/datasets)
# Get it from: https://huggingface.co/settings/tokens
# HUGGINGFACE_TOKEN=your_hf_token_here

# ===== Optional: Other Providers =====
# Google API Key (Optional - for Google search fallback)
# GOOGLE_API_KEY=your_google_api_key_here

# ===== General Settings =====
# Set to 'development' or 'production'
ENVIRONMENT=development

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
